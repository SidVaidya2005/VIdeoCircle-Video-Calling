{
  "name": "backend",
  "version": "1.0.0",
  "description": "Express 5 REST API for VideoCircle — user auth, meeting history, and LiveKit token issuance.",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Siddarth Vaidya",
  "license": "MIT",
  "overrides": {
    "tar": "^7.5.11"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "http-status": "^1.7.3",
    "livekit-server-sdk": "^2.15.1",
    "mongoose": "^8.0.3",
    "nodemon": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "vitest": "^4.1.6"
  }
}
